# 模型网关(多网关资源池)
# 主网关(必填):base_url 末尾含 /v1
# LLM_PROVIDER:openai = OpenAI 兼容格式(/v1/chat/completions);anthropic = Anthropic
# 原生格式(/v1/messages,Claude 模型/中转网关用,真 token 级流式)。白名单是 claude-* 时务必
# 设 anthropic,否则走 OpenAI 协议转换层会退化为假流式(整段返回)。
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://your-gateway/v1
LLM_API_KEY=your-gateway-key
# 附加网关(可选,按序号扩展;不需要可留空)
# LLM_GATEWAY_2_BASE_URL=https://your-second-gateway/v1
# LLM_GATEWAY_2_API_KEY=your-second-key
# 质量白名单(必填):允许使用的高质量模型裸 id,逗号分隔。
# 池 = 各网关 /v1/models 清单与此白名单求交集;不在白名单的模型永不被用。
# 首个 id 作为探测失败时的降级默认。
LLM_QUALITY_MODELS=claude-sonnet-4-6,claude-opus-4-1,gpt-4o
# 质检(rubric)分层 grader(可选):设为白名单内某个较弱/较快模型 id,文案质检走它、
# 把最强模型留给生成,显著降本;留空或不在池中则回退池首(最强)。读取时解析,改后下次评分即生效。
# XHS_RUBRIC_MODEL=claude-sonnet-4-6
# 关闭启动探测(测试/离线用):置 false 走降级单模型,不发网络请求
# DISCOVER_MODELS=false

# ── LangSmith 可观测(强烈建议开启)──────────────────────────────
# 开启后 deepagents/langgraph 全链路 trace 自动上报:能看 token 成本、
# 子智能体 trajectory、502 卡在哪一步。纯环境变量驱动,不需要改业务代码。
# 注意:上报走独立端点 api.smith.langchain.com,与模型中转无关——
# 若部署环境只放通了模型中转 IP,需额外放通这个域名,否则上报会静默失败。
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=xhs-content-agent
# 自托管/代理 LangSmith 时改这里,默认官方云端可留空。
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 飞书自建应用凭证(开放平台 → 企业自建应用)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
# 飞书爆款多维表格定位(从表格 URL 取:base/{app_token}?table={table_id})
FEISHU_BITABLE_APP_TOKEN=your-bitable-app-token
FEISHU_BITABLE_TABLE_ID=your-table-id
# 爆款采集库表 id(线上笔记"采纳收录"的镜像写入目标,独立于上面的草稿/选题主表)
FEISHU_BITABLE_COLLECT_TABLE_ID=tbl24vSVeLvz45ig
FEISHU_WIKI_SPACE_ID=7648177996175543260

# 红狐线上检索 API(search_xhs_online 实时搜小红书线上热门笔记)。留空则线上检索降级不可用。
REDFOX_API_KEY=your-redfox-api-key

# 多用户鉴权:与前端 web/.env 共享的 JWT 签名密钥(两端必须一致)。
# 配置后启用真飞书 OAuth 身份校验。生产必须配置 —— 留空时除非显式开下方 mock 开关,
# 否则一律 fail-closed(401),不会静默放行。
XHS_JWT_SECRET=change-me-to-a-long-random-secret
# 本地调试用 mock 身份模式开关。仅当无 XHS_JWT_SECRET 时生效,且**必须显式**设为 true
# 才接受 "Bearer mock-user-<id>" / XHS_DEV_FALLBACK_USER。生产严禁开启,留空即可。
XHS_AUTH_ALLOW_MOCK=
# 飞书用户令牌(UAT)落盘加密密钥。必须与 XHS_JWT_SECRET 不同 —— 两者解耦后,
# JWT 签名密钥泄露不会同时导致全员飞书令牌可被解密。留空则回退用 JWT 派生并告警。
XHS_UAT_ENCRYPTION_KEY=change-me-to-a-different-long-random-secret
# 管理员 open_id 白名单,逗号分隔;为空时没有用户可访问系统配置。
XHS_ADMIN_OPEN_IDS=
# Next server -> LangGraph internal HTTP. Both values are deploy-only.
XHS_INTERNAL_BASE_URL=http://127.0.0.1:2030
XHS_INTERNAL_SECRET=change-me-to-a-long-random-internal-secret
# 后端配置应用模式:manual 只保存配置;pm2/systemd 使用固定服务名重启后端。
XHS_BACKEND_APPLY_MODE=manual
XHS_BACKEND_PM2_NAME=xhs-backend
XHS_BACKEND_SYSTEMD_SERVICE=xhs-backend.service
XHS_PUBLIC_ORIGIN=http://localhost:3000
XHS_CONFIG_VERSION=
# 兜底用户:无 token 时的身份。上云前置空 → 无 token 直接返 401。
XHS_DEV_FALLBACK_USER=dev-user

# Phase 2 config center. Required for web-saved embedding configs to take effect
# without backend restarts. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
XHS_CONFIG_ENCRYPTION_KEY=
XHS_CONFIG_CENTER_PATH=.xhs-config/config-center.enc

# Phase 3 universal data foundation. Postgres is the authoritative resource store.
# The database must support pgcrypto and pgvector.
XHS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xhs
XHS_DEFAULT_TENANT_ID=default
# LangGraph ASGI lifespan owns the data-foundation supervisor. Enable on deployed backends.
XHS_SYNC_ENABLED=false
XHS_SCHEDULER_INTERVAL_SECONDS=30
XHS_SCHEDULER_SHUTDOWN_GRACE_SECONDS=10
# 第一次手动同步会注册持久化飞书 source；之后由 scheduler 每天增量拉取。
XHS_FEISHU_SYNC_INTERVAL_SECONDS=86400
# Embedding provider for semantic_search_resources. Independent from LLM_*; no fallback.
# With the config center enabled, these values bootstrap the first profile; UI saves create
# versioned profiles, and the scheduler builds a new index before switching it active.
XHS_EMBEDDING_BASE_URL=https://your-embedding-gateway/v1
XHS_EMBEDDING_API_KEY=your-embedding-key
XHS_EMBEDDING_MODEL=text-embedding-3-small
XHS_EMBEDDING_DIMENSIONS=1536
XHS_EMBEDDING_BATCH_SIZE=64
XHS_EMBEDDING_TIMEOUT_SECONDS=30
XHS_EMBEDDING_RELEVANCE_FLOOR=0.50
# Meilisearch _rankingScore 的绝对下限；低于此值不会进入 RRF。
XHS_KEYWORD_RELEVANCE_FLOOR=0.15

# Optional: tests may point at the same Postgres URL; pytest creates isolated schemas.
# TEST_XHS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xhs

# 检索引擎(全文 Meilisearch + 图谱 FalkorDB)。Docker 本地服务,只绑 127.0.0.1。
# 配置就绪后对应 outbox processor 自动 active;留空则 disabled。
XHS_MEILI_URL=http://127.0.0.1:7700
XHS_MEILI_KEY=change-me-to-meili-master-key
XHS_FALKOR_URL=redis://127.0.0.1:6379
XHS_FALKOR_GRAPH=xhs

# 部署底座(docker-compose 用,deploy-only):Postgres 主库口令。
XHS_PG_PASSWORD=change-me-to-pg-password
