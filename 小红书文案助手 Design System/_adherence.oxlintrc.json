{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/data/**",
              "components/device/**",
              "components/forms/**",
              "ui_kits/studio/**",
              "ui_kits/workbench/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Outfit|Inter))/i]",
        "message": "Font not provided by the design system. Available: Outfit, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|glyph|size|variant|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, glyph, size, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:coral|solid|neutral|agent)$/]",
        "message": "<Avatar> variant must be one of 'coral' | 'solid' | 'neutral' | 'agent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|shape|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, shape, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|synced|hot|topic|info|coral|draft)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'synced' | 'hot' | 'topic' | 'info' | 'coral' | 'draft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|chip)$/]",
        "message": "<Badge> shape must be one of 'pill' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|disabled|leftIcon|rightIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, disabled, leftIcon, rightIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|soft|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|tone|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, tone, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|sunken|coral)$/]",
        "message": "<Card> tone must be one of 'default' | 'sunken' | 'coral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HashtagTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|addable|onAdd|children|key|ref|className|style|children)$/]",
        "message": "<HashtagTag> doesn't accept that prop. Declared props: tone, addable, onAdd, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='HashtagTag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:topic|coral|plain)$/]",
        "message": "<HashtagTag> tone must be one of 'topic' | 'coral' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|rounded|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, variant, rounded, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|soft|solid|surface)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'soft' | 'solid' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='rounded'] > Literal[value!=/^(?:md|full)$/]",
        "message": "<IconButton> rounded must be one of 'md' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:leadingIcon|trailing|invalid|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: leadingIcon, trailing, invalid, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|author|authorInitial|likes|ratio|dim|key|ref|className|style|children)$/]",
        "message": "<NoteCard> doesn't accept that prop. Declared props: image, title, author, authorInitial, likes, ratio, dim."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhoneFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|children|key|ref|className|style|children)$/]",
        "message": "<PhoneFrame> doesn't accept that prop. Declared props: width, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|icon|tone|editable|onValueChange|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit, delta, icon, tone, editable, onValueChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|coral|topic|success)$/]",
        "message": "<StatCard> tone must be one of 'neutral' | 'coral' | 'topic' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:footer|invalid|rows|innerRef|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: footer, invalid, rows, innerRef, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThinkingStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|state|key|ref|className|style|children)$/]",
        "message": "<ThinkingStep> doesn't accept that prop. Declared props: label, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThinkingStep'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|active|pending)$/]",
        "message": "<ThinkingStep> state must be one of 'done' | 'active' | 'pending'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopicCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|rationale|hotRate|onClick|key|ref|className|style|children)$/]",
        "message": "<TopicCard> doesn't accept that prop. Declared props: index, title, rationale, hotRate, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
