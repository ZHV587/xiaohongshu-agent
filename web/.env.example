# LangGraph Configuration (BFF mode)
# 浏览器只访问同源 /api 代理;身份 JWT 存 httpOnly cookie,由代理服务端注入 Bearer。
NEXT_PUBLIC_API_URL=/api
# 服务端专用:代理转发的真实 LangGraph 后端地址(勿加 NEXT_PUBLIC_ 前缀,不进浏览器包)。
LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_ASSISTANT_ID=xhs_agent
# Optional. Required for Agent Builder deployments.
# Set to "langsmith-api-key" when using a LangSmith PAT.
NEXT_PUBLIC_AUTH_SCHEME=
# Do NOT prefix this with "NEXT_PUBLIC_" as we do not want this exposed in the client.
LANGSMITH_API_KEY=

# 飞书 OAuth（真登录，服务端用，勿加 NEXT_PUBLIC_ 前缀）
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
# 回调地址，须与飞书开放平台「重定向 URL」完全一致；本地默认即可
FEISHU_REDIRECT_URI=http://localhost:3000/api/auth/feishu/callback
# 与后端 auth.py 共享的 JWT 签名密钥（两端必须一致，随机长字符串）
XHS_JWT_SECRET=change-me-to-a-long-random-secret

# Production LangGraph Configuration (quickstart) - Uncomment to use
# NEXT_PUBLIC_ASSISTANT_ID="agent"
# 生产部署:LANGGRAPH_API_URL 指向真实后端;NEXT_PUBLIC_API_URL 始终保持同源 /api。
# LANGGRAPH_API_URL="https://my-agent.default.us.langgraph.app"
# LANGSMITH_API_KEY="lsv2_..."
